# ── Application ─────────────────────────────────────────────────────────────────
APP_NAME=DTAC-IR
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# ── API ──────────────────────────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Database ─────────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=dtac_ir
POSTGRES_USER=dtac_user
POSTGRES_PASSWORD=dtac_password
DATABASE_URL=postgresql+asyncpg://dtac_user:dtac_password@localhost:5432/dtac_ir

# ── Redis (for real-time event queue) ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Network Capture ──────────────────────────────────────────────────────────────
CAPTURE_INTERFACE=eth0
CAPTURE_FILTER=tcp or udp
PACKET_BUFFER_SIZE=1000

# ── ML Model ─────────────────────────────────────────────────────────────────────
MODEL_PATH=./ml/models/ids_model.pkl
SCALER_PATH=./ml/models/scaler.pkl
ML_CONFIDENCE_THRESHOLD=0.75

# ── Trust Scoring ────────────────────────────────────────────────────────────────
TRUST_SCORE_DECAY_RATE=0.05
TRUST_SCORE_MIN=0
TRUST_SCORE_MAX=100
TRUST_ALERT_THRESHOLD=30

# ── Automated Response ───────────────────────────────────────────────────────────
AUTO_BLOCK_ENABLED=false
AUTO_BLOCK_THRESHOLD=10
QUARANTINE_DURATION_MINUTES=60

# ── Alerting ─────────────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
ALERT_EMAIL=
SMTP_HOST=
SMTP_PORT=587
